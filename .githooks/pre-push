#!/usr/bin/env bash
set -euo pipefail

echo ">> pre-push: running CI checks locally..."

echo ">> checking formatting..."
cargo fmt --all -- --check
echo "   formatting OK"

echo ">> running clippy..."
cargo clippy --workspace --all-targets --all-features -- -D warnings
echo "   clippy OK"

echo ">> running tests (slow-tests skipped)..."
cargo test --workspace --features test-utils
echo "   tests OK"

echo ">> all CI checks passed"
