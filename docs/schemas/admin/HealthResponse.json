{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "HealthResponse",
  "type": "object",
  "properties": {
    "status": {
      "type": "string"
    },
    "runtime": {
      "type": "string"
    },
    "python_runtime": {
      "type": "boolean"
    },
    "backend": {
      "anyOf": [
        {
          "$ref": "#/$defs/HealthBackendResponse"
        },
        {
          "type": "null"
        }
      ]
    }
  },
  "required": [
    "status",
    "runtime",
    "python_runtime"
  ],
  "$defs": {
    "HealthBackendResponse": {
      "type": "object",
      "properties": {
        "status": {
          "type": "string"
        },
        "model": {
          "type": "string"
        },
        "backend": {
          "type": "string"
        },
        "reason": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "required": [
        "status",
        "model",
        "backend"
      ]
    }
  }
}